ARG BASE_IMAGE=8.0-cli-alpine3.16
FROM php:$BASE_IMAGE

RUN apk add --no-cache --virtual .build-deps autoconf \
     g++ \
     gcc \
     make \
     pkgconf \
     git \
     re2c

COPY . /tmp/simdjson

ENV REPORT_EXIT_STATUS=1
ENV NO_INTERACTION=1

RUN set -xe \
    && cd /tmp/simdjson \
    && phpize  \
    && ./configure  \
    && make -j$(nproc)  \
    && make install \
    && make test \
    && rm -rf /tmp/simdjson \
    && echo "extension=simdjson.so" > /usr/local/etc/php/conf.d/simdjson.ini
